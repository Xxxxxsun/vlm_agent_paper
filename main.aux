\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Exp~III: Training-free skill evolution vs.\ VTool-R1 (RL).} Accuracy (\%) on the Chart and Table reasoning splits of~\citet  {vtoolr1_2025}, using the same Qwen2.5-VL backbone at three scales. \textbf  {\#Train Traj.} is reserved for training-trajectory counts when available. {\fontfamily  {pzd}\fontencoding  {U}\fontseries  {m}\fontshape  {n}\selectfont  \char 51}~RL Update: model weights are updated via GRPO. {\fontfamily  {pzd}\fontencoding  {U}\fontseries  {m}\fontshape  {n}\selectfont  \char 55}~RL Update: weights are frozen. \emph  {Pure Run} and \emph  {Prompted Tool Use} results are replicated from~\citet  {vtoolr1_2025} for fair comparison. \textsc  {EvoAgent}{} closes a substantial fraction of the gap between \emph  {Pure Run} and VTool-R1 without any gradient updates. \relax }}{11}{table.caption.8}\protected@file@percent }
\newlabel{tab:vtoolr1_aligned_full}{{5}{11}{\textbf {Exp~III: Training-free skill evolution vs.\ VTool-R1 (RL).} Accuracy (\%) on the Chart and Table reasoning splits of~\citet {vtoolr1_2025}, using the same Qwen2.5-VL backbone at three scales. \textbf {\#Train Traj.} is reserved for training-trajectory counts when available. \ding {51}~RL Update: model weights are updated via GRPO. \ding {55}~RL Update: weights are frozen. \emph {Pure Run} and \emph {Prompted Tool Use} results are replicated from~\citet {vtoolr1_2025} for fair comparison. \sysname {} closes a substantial fraction of the gap between \emph {Pure Run} and VTool-R1 without any gradient updates. \relax }{table.caption.8}{}}
