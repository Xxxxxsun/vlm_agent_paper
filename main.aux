\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Exp~I: Autonomous evolution from scratch.} Accuracy (\%) for each evolution strategy across five foundation models and four benchmarks, all starting from an empty capability set. \emph  {None} is the zero-shot VLM baseline. \emph  {Skill Only} / \emph  {Tool Only} ablate one capability type. \emph  {Skill~$+$~Tool} is the full \textsc  {EvoAgent}{} system. Bold denotes the best result per model--benchmark pair. Consistent gains of Skill~$+$~Tool over the base agent confirm that training-free evolution is effective across both model families and all four benchmarks. \relax }}{8}{table.caption.3}\protected@file@percent }
\newlabel{tab:evolution_full}{{1}{8}{\textbf {Exp~I: Autonomous evolution from scratch.} Accuracy (\%) for each evolution strategy across five foundation models and four benchmarks, all starting from an empty capability set. \emph {None} is the zero-shot VLM baseline. \emph {Skill Only} / \emph {Tool Only} ablate one capability type. \emph {Skill~$+$~Tool} is the full \sysname {} system. Bold denotes the best result per model--benchmark pair. Consistent gains of Skill~$+$~Tool over the base agent confirm that training-free evolution is effective across both model families and all four benchmarks. \relax }{table.caption.3}{}}
\@writefile{toc}{\contentsline {paragraph}{Results on GTA.}{8}{subsection.4.3}\protected@file@percent }
