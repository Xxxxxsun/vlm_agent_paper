\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Comparison of evolution strategies across five foundation models and four benchmarks. We evaluate: \emph  {(1)}~no evolution (base agent), \emph  {(2)}~skill-only evolution, \emph  {(3)}~tool-only evolution, and \emph  {(4)}~joint skill--tool evolution. All variants start from an empty capability set with the same adaptation budget. Best result per model--benchmark pair in \textbf  {bold}. \relax }}{7}{table.caption.3}\protected@file@percent }
\newlabel{tab:evolution_full}{{1}{7}{Comparison of evolution strategies across five foundation models and four benchmarks. We evaluate: \emph {(1)}~no evolution (base agent), \emph {(2)}~skill-only evolution, \emph {(3)}~tool-only evolution, and \emph {(4)}~joint skill--tool evolution. All variants start from an empty capability set with the same adaptation budget. Best result per model--benchmark pair in \textbf {bold}. \relax }{table.caption.3}{}}
