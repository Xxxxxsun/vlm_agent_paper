\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces  \textbf  {\textsc  {EvoAgent}{} evolution loop and three-experiment overview.} {\em  (Left)}{}: on each failure, the AnalyzerDecider visually inspects the image and any tool outputs, diagnoses the bottleneck type (cognitive or perceptual), and directs the Generator to produce a reasoning skill (SOP), an executable visual tool (Python), or both. Capabilities are validated and accumulated for future cases. {\em  (Right)}{}: summary of the three experiments — from-scratch evolution (Exp I), mastery learning with pre-provided tools (Exp II), and gap to RL-trained VTool-R1 (Exp III). \relax }}{2}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:hero}{{1}{2}{\textbf {\sysname {} evolution loop and three-experiment overview.} \figleft {}: on each failure, the AnalyzerDecider visually inspects the image and any tool outputs, diagnoses the bottleneck type (cognitive or perceptual), and directs the Generator to produce a reasoning skill (SOP), an executable visual tool (Python), or both. Capabilities are validated and accumulated for future cases. \figright {}: summary of the three experiments — from-scratch evolution (Exp I), mastery learning with pre-provided tools (Exp II), and gap to RL-trained VTool-R1 (Exp III). \relax }{figure.caption.1}{}}
