\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {Exp~III: Positioning against Adaptive-CoF.} V$^\star $ and MME-RealWorld-Lite overall scores for Qwen2.5-VL-7B variants are reported from~\citet  {adaptivecof_2025}. The final row specifies the intended frozen-backbone \textsc  {EvoAgent}{} evaluation and is intentionally left as a placeholder until the same-protocol run is available. This comparison isolates a resource distinction: Adaptive-CoF learns adaptive zooming through task-specific SFT+RL data construction, whereas \textsc  {EvoAgent}{} aims to express the same class of behavior through self-evolved skills and tools. \relax }}{12}{table.caption.9}\protected@file@percent }
\newlabel{tab:adaptive_cof_positioning}{{6}{12}{\textbf {Exp~III: Positioning against Adaptive-CoF.} V$^\star $ and MME-RealWorld-Lite overall scores for Qwen2.5-VL-7B variants are reported from~\citet {adaptivecof_2025}. The final row specifies the intended frozen-backbone \sysname {} evaluation and is intentionally left as a placeholder until the same-protocol run is available. This comparison isolates a resource distinction: Adaptive-CoF learns adaptive zooming through task-specific SFT+RL data construction, whereas \sysname {} aims to express the same class of behavior through self-evolved skills and tools. \relax }{table.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces \textbf  {Ablation study.} Each row removes one component of \textsc  {EvoAgent}{} while holding all others fixed (GPT-4o backbone; $k{=}200$, $N{=}3$). \emph  {w/o Skill Evolution}: tool evolution only. \emph  {w/o Tool Evolution}: skill evolution only. \emph  {w/o Mastery Phase}: tools deployed unconditionally without applicability SOPs. \emph  {w/o Visual Diagnosis}: AnalyzerDecider receives only text (question, answer, trace) with no image input. Accuracy. \relax }}{12}{table.caption.10}\protected@file@percent }
\newlabel{tab:ablation_main}{{7}{12}{\textbf {Ablation study.} Each row removes one component of \sysname {} while holding all others fixed (GPT-4o backbone; $k{=}200$, $N{=}3$). \emph {w/o Skill Evolution}: tool evolution only. \emph {w/o Tool Evolution}: skill evolution only. \emph {w/o Mastery Phase}: tools deployed unconditionally without applicability SOPs. \emph {w/o Visual Diagnosis}: AnalyzerDecider receives only text (question, answer, trace) with no image input. Accuracy. \relax }{table.caption.10}{}}
