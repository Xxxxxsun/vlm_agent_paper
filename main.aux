\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Exp~III: unified comparison of direct inference, RL, self-evolution, and self-evolution+RL.} Scores are accuracy (\%). Chart and Table entries follow the VTool-R1 protocol; their RL rows are VTool-R1 GRPO results and their \textsc  {EvoAgent}{}+RL rows add the self-evolved capability on top of the RL-trained policy. V$^\star $ and HRBench4K entries follow the DeepEyes high-resolution evaluation; their RL rows are DeepEyes results where reported. A dash means the corresponding same-backbone or combined run is not reported in the source table and is not inferred here. \relax }}{11}{table.caption.8}\protected@file@percent }
\newlabel{tab:rl_combined}{{5}{11}{\textbf {Exp~III: unified comparison of direct inference, RL, self-evolution, and self-evolution+RL.} Scores are accuracy (\%). Chart and Table entries follow the VTool-R1 protocol; their RL rows are VTool-R1 GRPO results and their \sysname {}+RL rows add the self-evolved capability on top of the RL-trained policy. V$^\star $ and HRBench4K entries follow the DeepEyes high-resolution evaluation; their RL rows are DeepEyes results where reported. A dash means the corresponding same-backbone or combined run is not reported in the source table and is not inferred here. \relax }{table.caption.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {Ablation study.} Each row removes one component of \textsc  {EvoAgent}{} while holding all others fixed (GPT-4o backbone; $k{=}200$, $N{=}3$). \emph  {w/o Skill Evolution}: tool evolution only. \emph  {w/o Tool Evolution}: skill evolution only. \emph  {w/o Mastery Phase}: tools deployed unconditionally without applicability SOPs. \emph  {w/o Visual Diagnosis}: AnalyzerDecider receives only text (question, answer, trace) with no image input. Accuracy. \relax }}{11}{table.caption.9}\protected@file@percent }
\newlabel{tab:ablation_main}{{6}{11}{\textbf {Ablation study.} Each row removes one component of \sysname {} while holding all others fixed (GPT-4o backbone; $k{=}200$, $N{=}3$). \emph {w/o Skill Evolution}: tool evolution only. \emph {w/o Tool Evolution}: skill evolution only. \emph {w/o Mastery Phase}: tools deployed unconditionally without applicability SOPs. \emph {w/o Visual Diagnosis}: AnalyzerDecider receives only text (question, answer, trace) with no image input. Accuracy. \relax }{table.caption.9}{}}
