\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Results under the \emph  {cumulative streaming} setting, where benchmarks are introduced sequentially and the agent must continuously adapt to the growing task distribution. Each column reports accuracy on all benchmarks seen so far; \textbf  {Final Avg.}\ averages over all four benchmarks. We compare static and naive accumulation strategies against our dynamic skill--tool co-evolution framework. \relax }}{8}{table.caption.4}\protected@file@percent }
\newlabel{tab:streaming_accumulation}{{2}{8}{Results under the \emph {cumulative streaming} setting, where benchmarks are introduced sequentially and the agent must continuously adapt to the growing task distribution. Each column reports accuracy on all benchmarks seen so far; \textbf {Final Avg.}\ averages over all four benchmarks. We compare static and naive accumulation strategies against our dynamic skill--tool co-evolution framework. \relax }{table.caption.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Detailed evaluation on the GTA benchmark. We report step-level tool-use accuracy (\textbf  {ToolAcc}: correct tool selected; \textbf  {ArgAcc}: correct arguments; \textbf  {InstAcc}: correct instruction following) and final task accuracy (\textbf  {AnsAcc}). \emph  {Skill Evolution (Ours)} corresponds to \textsc  {EvoAgent}{} Mode~B, which applies mastery profiling to the provided tool set without generating new tools. \relax }}{8}{table.caption.5}\protected@file@percent }
\newlabel{tab:gta_detailed}{{3}{8}{Detailed evaluation on the GTA benchmark. We report step-level tool-use accuracy (\textbf {ToolAcc}: correct tool selected; \textbf {ArgAcc}: correct arguments; \textbf {InstAcc}: correct instruction following) and final task accuracy (\textbf {AnsAcc}). \emph {Skill Evolution (Ours)} corresponds to \sysname {} Mode~B, which applies mastery profiling to the provided tool set without generating new tools. \relax }{table.caption.5}{}}
