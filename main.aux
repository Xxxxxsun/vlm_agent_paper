\newlabel{sec:exp3}{{4.4}{8}{Experiment~III: Closing the Gap to VTool-R1}{subsection.4.4}{}}
\@writefile{toc}{\contentsline {paragraph}{Motivation.}{8}{subsection.4.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Exp~I: Cumulative streaming setting.} Benchmarks are introduced sequentially from left to right; each cell reports accuracy on \emph  {all benchmarks seen so far}. \textbf  {Final Avg.} is the mean accuracy over all four benchmarks after the full stream. Dynamic co-evolution maintains consistent gains across the growing distribution, whereas naive accumulation degrades on earlier benchmarks as later ones are added — indicating capability interference when no revalidation is applied. \relax }}{9}{table.caption.4}\protected@file@percent }
\newlabel{tab:streaming_accumulation}{{2}{9}{\textbf {Exp~I: Cumulative streaming setting.} Benchmarks are introduced sequentially from left to right; each cell reports accuracy on \emph {all benchmarks seen so far}. \textbf {Final Avg.} is the mean accuracy over all four benchmarks after the full stream. Dynamic co-evolution maintains consistent gains across the growing distribution, whereas naive accumulation degrades on earlier benchmarks as later ones are added — indicating capability interference when no revalidation is applied. \relax }{table.caption.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Exp~II: Learning to use pre-provided tools on GTA.} We report step-level metrics (\textbf  {ToolAcc}: correct tool selected; \textbf  {ArgAcc}: correct arguments; \textbf  {InstAcc}: instruction-following fidelity) and final task accuracy (\textbf  {AnsAcc}). \emph  {Tool Usage Tuning} invokes all tools unconditionally; \emph  {Skill Evolution (Ours)} applies \textsc  {EvoAgent}{} Mode~B, which learns per-tool mastery SOPs from the training set without generating new tools. The gap between \emph  {Tool Usage Tuning} and \emph  {Ours} isolates the benefit of mastery-guided conditional invocation over naive tool deployment. \relax }}{9}{table.caption.5}\protected@file@percent }
\newlabel{tab:gta_detailed}{{3}{9}{\textbf {Exp~II: Learning to use pre-provided tools on GTA.} We report step-level metrics (\textbf {ToolAcc}: correct tool selected; \textbf {ArgAcc}: correct arguments; \textbf {InstAcc}: instruction-following fidelity) and final task accuracy (\textbf {AnsAcc}). \emph {Tool Usage Tuning} invokes all tools unconditionally; \emph {Skill Evolution (Ours)} applies \sysname {} Mode~B, which learns per-tool mastery SOPs from the training set without generating new tools. The gap between \emph {Tool Usage Tuning} and \emph {Ours} isolates the benefit of mastery-guided conditional invocation over naive tool deployment. \relax }{table.caption.5}{}}
