\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Exp~I: Distribution-shift adaptation in a non-stationary stream.} The stream begins with HRBench-only capabilities and later introduces MathVista, ChartQA, and V$^*$ cases. \emph  {Static HR} never adapts beyond the initial HRBench pack; \emph  {Online adapt} detects new task families and activates the corresponding capability pack; \emph  {Oracle} has all packs from the beginning. Rows are grouped by model profile, and protocols within a block describe how the replay stream is constructed. Standard deviations are temporary layout placeholders and must be replaced with seed-based estimates before submission. \relax }}{9}{table.caption.5}\protected@file@percent }
\newlabel{tab:distribution_shift}{{2}{9}{\textbf {Exp~I: Distribution-shift adaptation in a non-stationary stream.} The stream begins with HRBench-only capabilities and later introduces MathVista, ChartQA, and V$^*$ cases. \emph {Static HR} never adapts beyond the initial HRBench pack; \emph {Online adapt} detects new task families and activates the corresponding capability pack; \emph {Oracle} has all packs from the beginning. Rows are grouped by model profile, and protocols within a block describe how the replay stream is constructed. Standard deviations are temporary layout placeholders and must be replaced with seed-based estimates before submission. \relax }{table.caption.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Exp~II: Learning to use pre-provided tools on GTA.} We report step-level metrics (\textbf  {ToolAcc}: correct tool selected; \textbf  {ArgAcc}: correct arguments; \textbf  {InstAcc}: instruction-following fidelity) and final task accuracy (\textbf  {AnsAcc}). \emph  {Skill Evolution (Ours)} applies \textsc  {EvoAgent}{} Mode~B, which learns per-tool mastery SOPs from the training set without generating new tools. \relax }}{9}{table.caption.6}\protected@file@percent }
\newlabel{tab:gta_detailed}{{3}{9}{\textbf {Exp~II: Learning to use pre-provided tools on GTA.} We report step-level metrics (\textbf {ToolAcc}: correct tool selected; \textbf {ArgAcc}: correct arguments; \textbf {InstAcc}: instruction-following fidelity) and final task accuracy (\textbf {AnsAcc}). \emph {Skill Evolution (Ours)} applies \sysname {} Mode~B, which learns per-tool mastery SOPs from the training set without generating new tools. \relax }{table.caption.6}{}}
