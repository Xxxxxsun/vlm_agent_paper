\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Aligned comparison with VTool-R1~\citep  {vtoolr1_2025} on fixed-tool visual reasoning. VTool-R1 improves tool-use behaviour via GRPO-based reinforcement learning ({\fontfamily  {pzd}\fontencoding  {U}\fontseries  {m}\fontshape  {n}\selectfont  \char 51}~RL Update); our method performs explicit skill evolution over the same predefined tool library with no weight updates ({\fontfamily  {pzd}\fontencoding  {U}\fontseries  {m}\fontshape  {n}\selectfont  \char 55}~RL Update). \textbf  {\#Train Traj.}\ reports the number of training trajectories consumed by each method. Results for Pure Run and Prompted Tool Use are replicated from~\citet  {vtoolr1_2025} for fair comparison. \relax }}{9}{table.caption.6}\protected@file@percent }
\newlabel{tab:vtoolr1_aligned_full}{{4}{9}{Aligned comparison with VTool-R1~\citep {vtoolr1_2025} on fixed-tool visual reasoning. VTool-R1 improves tool-use behaviour via GRPO-based reinforcement learning (\ding {51}~RL Update); our method performs explicit skill evolution over the same predefined tool library with no weight updates (\ding {55}~RL Update). \textbf {\#Train Traj.}\ reports the number of training trajectories consumed by each method. Results for Pure Run and Prompted Tool Use are replicated from~\citet {vtoolr1_2025} for fair comparison. \relax }{table.caption.6}{}}
